# ============================================================
# ChatGPT2API 配置
# ============================================================

# ChatGPT Access Token（必填）
# 获取方式：登录 chatgpt.com → 访问 https://chatgpt.com/api/auth/session → 复制 accessToken
CHATGPT_ACCESS_TOKEN=

# 出站代理（必填，需能访问 chatgpt.com）
# 支持 http / https / socks5
PROXY_URL=http://127.0.0.1:7890

# ChatGPT 地址（一般不需要改）
CHATGPT_BASE_URL=https://chatgpt.com

# 服务端口
PORT=8700

# 请求超时（秒）
TIMEOUT=600

# 图片生成使用的模型
WEB_IMAGE_MODEL=gpt-5-5-thinking

# 对话默认模型
WEB_CHAT_MODEL=gpt-4o
